{
  "manifest_version": 3,
  "name": "Workflow Recorder & Player",
  "version": "1.0.0",
  "description": "Record, replay, and screenshot workflows across any web app.",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "webNavigation",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>",
    "*://*/*",
    "http://*/*",
    "https://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Workflow Recorder"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>",
        "*://*/*",
        "http://*/*",
        "https://*/*"
      ],
      "js": ["content/recorder.js", "content/player.js", "content/logs-dialog.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>", "*://*/*"],
      "js": ["content/page-interceptor.js", "content/playback-capture.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/playback-capture.js", "content/page-interceptor.js"],
      "matches": [
        "<all_urls>",
        "*://*/*"
      ]
    }
  ]
}
